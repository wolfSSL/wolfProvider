name: tpm2-tss Tests
on:
  push:
    branches: [ 'master', 'main', 'release/**' ]
  pull_request:
    branches: [ '*' ]
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true
jobs:
  build_wolfprovider:
    uses: ./.github/workflows/build-wolfprovider.yml
    with:
      wolfssl_ref: ${{ matrix.wolfssl_ref }}
      openssl_ref: ${{ matrix.openssl_ref }}
    strategy:
      matrix:
        wolfssl_ref: [ 'master', 'v5.8.0-stable' ]
        openssl_ref: [ 'openssl-3.5.0' ]
  test_tpm2_tss:
    runs-on: ubuntu-22.04
    needs: build_wolfprovider
    timeout-minutes: 30
    strategy:
      matrix:
        wolfssl_ref: [ 'master', 'v5.8.0-stable' ]
        openssl_ref: [ 'openssl-3.5.0' ]
        tpm2_tss_ref: [ 'main', '4.1.3' ]
        force_fail: [ 'WOLFPROV_FORCE_FAIL=1', '' ]
        exclude:
          - tpm2_tss_ref: 'main'
            force_fail: 'WOLFPROV_FORCE_FAIL=1'
    steps:
      - name: Checkout wolfProvider
        uses: actions/checkout@v4
        with:
          fetch-depth: 1
      - name: Retrieving wolfSSL/wolfProvider from cache
        uses: actions/cache/restore@v4
        id: wolfprov-cache
        with:
          path: |
            scripts
            wolfssl-source
            wolfssl-install
            wolfprov-install
            openssl-install
            provider.conf
          key: wolfprov-${{ matrix.wolfssl_ref }}-${{ matrix.openssl_ref }}-${{ github.sha }}
          fail-on-cache-miss: true
      - name: Install test dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y pkg-config libjson-c-dev libcurl4-openssl-dev uuid-dev libcmocka-dev build-essential autoconf automake libtool libssl-dev
      - name: Checkout tpm2-tss
        uses: actions/checkout@v4
        with:
          repository: tpm2-software/tpm2-tss
          path: tpm2_tss_repo
          ref: ${{ matrix.tpm2_tss_ref }}
          fetch-depth: 1
      - name: Build and install tpm2-tss
        working-directory: tpm2_tss_repo
        run: |
          ./bootstrap
          ./configure --prefix=$GITHUB_WORKSPACE/tpm2-tss-install --with-crypto=ossl --enable-unit
          make -j$(nproc)
          make install
      - name: Run tpm2-tss tests
        working-directory: tpm2_tss_repo
        run: |
          source $GITHUB_WORKSPACE/scripts/env-setup
          export ${{ matrix.force_fail }}
          # Run tests and capture output
          make check 2>&1 | tee test-suite.log

          # Check for failures in ESYS unit tests
          if grep -q "FAIL.*test/unit/esys" test-suite.log; then
            echo "FAILURES detected in ESYS unit tests."
            ESYS_HAS_FAIL=true # Declared and set here if condition is true
          else
            echo "No failures detected in ESYS unit tests."
            ESYS_HAS_FAIL=false # Declared and set here if condition is false
          fi

          # Check for failures in FAPI unit tests
          if grep -q "FAIL.*test/unit/fapi" test-suite.log; then
            echo "FAILURES detected in FAPI unit tests."
            FAPI_HAS_FAIL=true # Declared and set here if condition is true
          else
            echo "No failures detected in FAPI unit tests."
            FAPI_HAS_FAIL=false # Declared and set here if condition is false
          fi

          # Determine overall test result
          if [ "$ESYS_HAS_FAIL" = "true" ] || [ "$FAPI_HAS_FAIL" = "true" ]; then
            TEST_RESULT=1 # Declared and set here if condition is true
            echo "Overall: TPM2-TSS tests FAILED due to ESYS or FAPI failures."
            echo "Detailed Failures:"
            grep -A 10 "FAIL: test/unit/esys" test-suite.log || true # Show context for ESYS failures
            grep -A 10 "FAIL: test/unit/fapi" test-suite.log || true # Show context for FAPI failures
            grep "FAILED TEST(S)" test-suite.log || true # Show overall failed test count
          else
            TEST_RESULT=0
            echo "Overall: TPM2-TSS tests PASSED (no failures in ESYS or FAPI unit tests)."
          fi

          $GITHUB_WORKSPACE/.github/scripts/check-workflow-result.sh $TEST_RESULT ${{ matrix.force_fail }} tpm2-tss

